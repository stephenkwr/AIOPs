# Copy to backend/.env and fill in. NEVER commit the real .env (it is gitignored).
# See README "Secrets" section for how this maps to production practice.

APP_ENV=local

# --- Database ---------------------------------------------------------------
# Local (docker-compose): both point at the local Postgres.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/copilot
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres:postgres@localhost:5432/copilot
#
# Supabase (production) — two different connections:
#   DATABASE_URL         -> transaction pooler, host ...pooler.supabase.com:6543  (app runtime)
#   DATABASE_URL_DIRECT  -> direct connection,  host db.<ref>.supabase.co:5432    (migrations)
# Use the "asyncpg" driver prefix: postgresql+asyncpg://...

# --- CORS -------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# --- LLM providers (not needed until Phase 1+) ------------------------------
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# --- Model selection (defaults are fine to leave blank) ---------------------
AGENT_MODEL=gemini-flash-latest
JUDGE_MODEL=llama-3.3-70b-versatile
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=768

# --- Ingestion --------------------------------------------------------------
# embed_provider: auto = use Gemini if GEMINI_API_KEY is set, else an offline
# hashing embedder (no key needed — great for local dev & CI). Force with gemini|fake.
EMBED_PROVIDER=auto
STORAGE_DIR=./_storage
MAX_UPLOAD_MB=10
CHUNKER=structure          # structure | naive
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_RATIO=0.15
